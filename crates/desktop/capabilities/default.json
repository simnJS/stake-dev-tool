{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities for the Stake Dev Tool main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:event:default",
    "dialog:default",
    "dialog:allow-open",
    "shell:default",
    "opener:default",
    "opener:allow-open-url",
    "updater:default",
    "process:default",
    "process:allow-restart"
  ]
}
