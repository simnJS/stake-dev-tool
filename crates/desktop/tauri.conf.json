{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Stake Dev Tool",
  "version": "0.3.0",
  "identifier": "bet.playandchill.stakedevtool",
  "build": {
    "beforeDevCommand": "pnpm --filter ui dev",
    "beforeBuildCommand": "pnpm --filter ui build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../ui/build"
  },
  "app": {
    "windows": [
      {
        "title": "Stake Dev Tool",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "resizable": true,
        "fullscreen": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "app", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/simnJS/stake-dev-tool/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgxNDU4RDc1MDM0NTE0RUIKUldUckZFVURkWTFGZ2Q3MWRJbVR0Zm1lT1laRlZjL2NROVBaV2Y3LzdIais4SURqdkJoRkdHVmgK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
