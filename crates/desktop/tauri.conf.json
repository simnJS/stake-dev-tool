{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Stake Dev Tool",
  "version": "0.1.0",
  "identifier": "bet.playandchill.stakedevtool",
  "build": {
    "beforeDevCommand": "pnpm --filter ui dev",
    "beforeBuildCommand": "pnpm --filter ui build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../ui/build"
  },
  "app": {
    "windows": [
      {
        "title": "Stake Dev Tool",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "resizable": true,
        "fullscreen": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
